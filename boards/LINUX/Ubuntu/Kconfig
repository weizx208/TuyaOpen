config CHIP_CHOICE
    string
    default "Ubuntu"

config BOARD_CHOICE
    string
    default "Ubuntu"

config BOARD_CONFIG
    bool
    default y
    select ENABLE_QRCODE

config ENABLE_SDL_DISPLAY
    bool "Enable SDL2 desktop window for display"
    depends on ENABLE_DISPLAY
    default y
    ---help---
        Enable a simple SDL2 window as the display device.
        This is useful on Ubuntu Desktop to show LVGL UI in a small window.